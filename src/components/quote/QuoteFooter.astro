---
import Logo from '../Logo.astro';
import type { Provider } from '../../types/invoice';

interface Props {
  provider: Provider;
  documentNumber: string;
}

const { provider, documentNumber } = Astro.props;
---

<div class="invoice-footer">
  <div class="invoice-footer-brand">
    <Logo size="sm" />
    <span class="invoice-footer-text" id="q-footer-contact">
      {provider.website} · {provider.email} · {provider.phone}
    </span>
  </div>
  <span class="invoice-footer-code" id="q-footer-code">{documentNumber}</span>
</div>
