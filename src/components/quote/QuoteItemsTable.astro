---
import type { QuoteItem } from '../../types/quote';
import { fmt } from '../../utils/format';

interface Props {
  items: QuoteItem[];
}

const { items } = Astro.props;
---

<div class="items-table-wrap">
  <table class="items-table q-items-table">
    <thead>
      <tr>
        <th style="width: 52%;">Ítem · descripción</th>
        <th style="width: 10%; text-align:center;">Cant.</th>
        <th style="width: 19%; text-align:right;">Valor unit.</th>
        <th style="width: 19%; text-align:right;">Total</th>
      </tr>
    </thead>
    <tbody id="q-items-body">
      {items.map(item => (
        <tr>
          <td data-label="Ítem · descripción">
            <span class="q-item-tag">{item.tag}</span>
            <p class="item-name">{item.name}</p>
            {item.description && <p class="item-desc">{item.description}</p>}
          </td>
          <td data-label="Cant.">{item.quantity}</td>
          <td data-label="Valor unit.">{fmt(item.unitPrice)}</td>
          <td data-label="Total">{fmt(item.quantity * item.unitPrice)}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
