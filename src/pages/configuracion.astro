---
import AppLayout from '../layouts/AppLayout.astro';
import ConfigIntro from '../components/settings/ConfigIntro.astro';
import WizardTabs from '../components/settings/WizardTabs.astro';
import SettingsWorkspace from '../components/settings/SettingsWorkspace.astro';
---

<AppLayout title="Configuración — Cuenta de Cobro" current="configuracion" suffix="Configuración">
  <style slot="head">
    body { padding: var(--page-pad) var(--page-pad) clamp(56px, 8vw, 80px); }
    .page { max-width: 1160px; margin: 0 auto; width: 100%; }

    .config-intro {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: var(--content-gap);
      align-items: end;
      margin-bottom: 22px;
    }
    .config-title {
      font-family: var(--font-heading);
      font-size: clamp(2rem, 5vw, 4rem);
      line-height: .95;
      color: var(--black);
      margin-bottom: 10px;
    }
    .config-copy {
      color: var(--text-secondary);
      max-width: 62ch;
      line-height: 1.7;
    }
    .wizard-status {
      font-family: var(--font-mono);
      font-size: 12px;
      color: var(--gray-600);
      white-space: nowrap;
    }
    .wizard-progress {
      height: 8px;
      background: var(--gray-200);
      border-radius: var(--r-full);
      overflow: hidden;
      margin-bottom: 14px;
    }
    .wizard-progress-bar {
      width: 20%;
      height: 100%;
      background: var(--gold);
      transition: width .2s ease;
    }
    .wizard-tabs {
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 8px;
      margin-bottom: var(--section-gap);
    }
    .wizard-tab {
      border: 1.5px solid var(--warm-border);
      background: #fff;
      color: var(--gray-800);
      border-radius: var(--r-md);
      padding: 10px 12px;
      cursor: pointer;
      font-family: var(--font-body);
      font-size: 12px;
      font-weight: 700;
      text-align: left;
      transition: border-color .16s, background .16s, color .16s;
    }
    .wizard-tab span {
      display: block;
      font-family: var(--font-mono);
      font-size: 10px;
      color: var(--gray-600);
      margin-bottom: 2px;
    }
    .wizard-tab.is-active {
      border-color: var(--gold);
      background: var(--gold-subtle);
      color: var(--black);
    }

    .settings-layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(300px, 360px);
      gap: var(--section-gap);
      align-items: start;
    }
    .form-panel { display: flex; flex-direction: column; gap: var(--content-gap); min-width: 0; }
    .wizard-panel { display: none; }
    .wizard-panel.is-active { display: block; }
    .step-help {
      background: var(--emerald-subtle);
      border: 1px solid rgba(23,160,120,.22);
      color: var(--emerald-dark);
      border-radius: var(--r-md);
      padding: 14px 16px;
      font-size: 13px;
      line-height: 1.55;
      margin-bottom: 16px;
    }
    .validation-note {
      display: none;
      color: #9d4b00;
      background: #fff7df;
      border: 1px solid #f0d487;
      border-radius: var(--r-md);
      padding: 10px 12px;
      font-size: 13px;
      margin-bottom: 14px;
    }
    .validation-note.visible { display: block; }
    .wizard-controls {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 18px;
    }
    .review-list {
      display: grid;
      gap: 12px;
    }
    .review-row {
      display: grid;
      grid-template-columns: minmax(120px, 150px) minmax(0, 1fr);
      gap: 12px;
      padding: 12px 0;
      border-bottom: 1px solid var(--gray-200);
      font-size: 14px;
    }
    .review-row:last-child { border-bottom: none; }
    .review-row strong {
      color: var(--gray-800);
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: .8px;
    }
    .preview-panel {
      position: sticky;
      top: 24px;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }
    .color-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
    }
    .logo-control {
      display: grid;
      grid-template-columns: 72px minmax(0, 1fr);
      gap: 14px;
      align-items: center;
    }
    .logo-preview,
    .signature-preview {
      width: 64px;
      height: 64px;
      border-radius: var(--r-md);
      background: var(--gray-100);
      border: 1px solid var(--warm-border);
      display: grid;
      place-items: center;
      overflow: hidden;
    }
    .signature-preview {
      width: 128px;
      height: 72px;
      background: #fff;
    }
    .logo-preview img,
    .logo-preview svg {
      width: 48px;
      height: 48px;
      object-fit: contain;
    }
    .signature-preview img {
      max-width: 112px;
      max-height: 56px;
      object-fit: contain;
    }
    .signature-placeholder {
      font-family: var(--font-mono);
      font-size: 10px;
      color: var(--gray-600);
      text-align: center;
      padding: 8px;
    }
    .preview-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--r-lg);
      box-shadow: var(--shadow-sm);
      overflow: hidden;
    }
    .brand-strip {
      background: var(--black);
      padding: 28px;
      color: #fff;
      display: flex;
      justify-content: space-between;
      gap: 18px;
      align-items: flex-start;
    }
    .brand-preview-title {
      font-family: var(--font-heading);
      color: var(--gold);
      font-size: 1.7rem;
      line-height: 1;
      margin-top: 8px;
    }
    .brand-preview-subtitle {
      color: rgba(255,255,255,.5);
      font-size: 13px;
      margin-top: 8px;
    }
    .preview-body {
      padding: 22px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .preview-name {
      font-family: var(--font-heading);
      font-weight: 700;
      color: var(--text);
    }
    .preview-detail {
      font-size: 13px;
      color: var(--text-secondary);
      line-height: 1.7;
    }
    .preview-payment {
      background: var(--navy-subtle);
      border: 1px solid #cde0ea;
      border-radius: var(--r-md);
      padding: 14px;
      font-family: var(--font-mono);
      font-size: 12px;
      color: var(--navy-dark);
    }
    .actions-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--r-lg);
      box-shadow: var(--shadow-sm);
      padding: 18px;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .danger-btn {
      color: #a13030;
      border-color: #efc7c7;
    }
    .danger-btn:hover {
      color: #7f1d1d;
      border-color: #d97979;
      background: #fff2f2;
    }

    @media (max-width: 980px) {
      .settings-layout { grid-template-columns: 1fr; }
      .preview-panel { position: static; }
      .wizard-tabs { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    }
    @media (max-width: 700px) {
      .config-intro { grid-template-columns: 1fr; }
      .field-grid,
      .field-grid.col3 { grid-template-columns: 1fr; }
      .color-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .wizard-tabs { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .review-row { grid-template-columns: 1fr; }
      .wizard-controls {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .wizard-controls > * { justify-content: center; }
      .logo-control {
        grid-template-columns: 1fr;
      }
      .brand-strip {
        padding: 22px;
      }
    }

    @media (max-width: 420px) {
      .wizard-tabs,
      .wizard-controls,
      .color-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

    <ConfigIntro />
    <WizardTabs />
    <SettingsWorkspace />
  <script slot="scripts">
    import { initSettingsPage } from '../scripts/pages/settings-page.js';

    initSettingsPage();
  </script>
</AppLayout>
