---
import { PROVIDER } from '../config/provider';
import defaultQuote from '../data/quote.default.json';
import AppLayout from '../layouts/AppLayout.astro';
import QuoteEditorActions from '../components/quote-editor/QuoteEditorActions.astro';
import QuoteEditorWorkspace from '../components/quote-editor/QuoteEditorWorkspace.astro';

const defaultData = JSON.stringify({ quote: defaultQuote, provider: PROVIDER });
---

<AppLayout title="Editor — Cotización" current="cotizacion" suffix="Editor">
  <style is:global slot="head">
    body { padding: var(--page-pad) var(--page-pad) clamp(56px, 8vw, 80px); }
    .page { max-width: 1160px; margin: 0 auto; width: 100%; }

    .editor-actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      align-items: center;
      justify-content: flex-end;
      margin-bottom: var(--content-gap);
    }

    /* Two-column layout */
    .editor-layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(280px, 320px);
      gap: var(--section-gap);
      align-items: start;
    }

    .form-panel {
      display: flex;
      flex-direction: column;
      gap: var(--content-gap);
      min-width: 0;
    }

    .preview-panel {
      position: sticky;
      top: 24px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    /* Toggle rows */
    .toggle-row {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .toggle-row label {
      font-family: var(--font-body);
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 8px;
      color: var(--text);
    }
    .sub-fields { display: none; margin-top: 14px; }
    .sub-fields.visible { display: grid; }

    /* Save indicator */
    #qprev-save-badge.dirty { background: var(--gold-subtle); color: var(--gold-dark); }

    @media (max-width: 980px) {
      .editor-layout { grid-template-columns: 1fr; }
      .preview-panel { position: static; }
    }
    @media (max-width: 640px) {
      .editor-actions {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .editor-actions > * { justify-content: center; min-width: 0; }
    }
    @media (max-width: 420px) {
      .editor-actions { grid-template-columns: 1fr; }
    }
  </style>

  <QuoteEditorActions />
  <QuoteEditorWorkspace />

  <script is:inline slot="scripts" type="application/json" id="qeditor-default-data" set:html={defaultData}></script>
</AppLayout>

<script>
  import { initQuoteEditorPage } from '../scripts/pages/quote-editor-page.js';
  initQuoteEditorPage();
</script>
