---
import { PROVIDER } from '../config/provider';
import defaultInvoice from '../data/invoice.default.json';
import { fmtDate, calcTotals } from '../utils/format';
import AppLayout from '../layouts/AppLayout.astro';

// ── Components ─────────────────────────────────────────────────
import DocumentActions from '../components/invoice/DocumentActions.astro';
import InvoiceDocument from '../components/invoice/InvoiceDocument.astro';

// ── Server-side data + calculations ───────────────────────────
const inv = defaultInvoice;
const { subtotal, retentionAmt, total } = calcTotals(inv);

const statusLabel = inv.status === 'paid' ? 'Pagado' : 'Pendiente de pago';
const statusClass = inv.status === 'paid' ? 'badge-paid' : 'badge-pending';
const issuedLabel = fmtDate(inv.issuedAt);
const dueLabel    = inv.dueDate ? fmtDate(inv.dueDate) : '—';

// Serialise for client-side hydration
const defaultData = JSON.stringify({ invoice: inv, provider: PROVIDER });
---

<AppLayout title="Cuenta de Cobro" current="cuenta">
  <style slot="head">
    /* ── Page shell (screen-only, not part of invoice) ── */
    body { padding: var(--page-pad) var(--page-pad) clamp(56px, 8vw, 80px); }
    .page { max-width: 780px; margin: 0 auto; width: 100%; }

    .document-actions {
      display: flex;
      gap: 8px;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: 24px;
    }

    .upload-hint { text-align: center; font-size: 12px; color: var(--gray-600); margin-top: 16px; }
    .upload-hint a { color: var(--emerald); text-decoration: none; font-weight: 500; }
    .upload-hint a:hover { text-decoration: underline; }

    @media (max-width: 720px) {
      .document-actions {
        width: 100%;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .document-actions > * {
        justify-content: center;
        min-width: 0;
      }
    }

    @media (max-width: 460px) {
      .document-actions { grid-template-columns: 1fr; }
    }

    /* ── Print ── */
    @media print {
      body { background: #fff; padding: 0; }
      .app-nav, .document-actions, .upload-hint { display: none !important; }
      .page { max-width: 100%; }
      .invoice { border-radius: 0; box-shadow: none; border: none; }
      .items-table tbody tr:hover { background: transparent; }
    }
    @page { size: A4; margin: 16mm 12mm; }
  </style>

    <DocumentActions />

    <InvoiceDocument
      provider={PROVIDER}
      invoice={inv}
      issuedLabel={issuedLabel}
      dueLabel={dueLabel}
      statusLabel={statusLabel}
      statusClass={statusClass}
      subtotal={subtotal}
      retentionAmt={retentionAmt}
      total={total}
    />

    <p class="upload-hint">
      ¿Quieres generar una nueva cuenta de cobro?
      <a href="/editor">Crea una nueva</a>, revisa el <a href="/historico">histórico</a> o carga un JSON.
    </p>

  <!-- ══════════════════════════════════════════════════════════
       CLIENT-SIDE LOGIC
       Reads state from localStorage (set by editor) or default
       data, then re-renders the invoice DOM when data changes.
       ══════════════════════════════════════════════════════════ -->
  <script slot="scripts" type="application/json" id="default-data" set:html={defaultData}></script>

  <script slot="scripts">
    import { initInvoicePage } from '../scripts/pages/invoice-page.js';

    initInvoicePage();
  </script>
</AppLayout>
