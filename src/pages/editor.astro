---
import { PROVIDER } from '../config/provider';
import defaultInvoice from '../data/invoice.default.json';
import '../styles/design-system.css';
import AppNav        from '../components/AppNav.astro';
import SectionCard   from '../components/editor/SectionCard.astro';
import JsonPreview   from '../components/editor/JsonPreview.astro';
import TotalsPreview from '../components/editor/TotalsPreview.astro';

const defaultData = JSON.stringify({ invoice: defaultInvoice, provider: PROVIDER });
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Editor — Cuenta de Cobro</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="manifest" href="/manifest.webmanifest" />

  <style>
    body { padding: 32px 24px 80px; }
    .page { max-width: 1160px; margin: 0 auto; }

    .editor-actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      align-items: center;
      justify-content: flex-end;
      margin-bottom: 24px;
    }

    /* ── TWO-COLUMN LAYOUT ── */
    .editor-layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 340px;
      gap: 32px;
      align-items: start;
    }

    /* ── FORM PANEL ── */
    .form-panel { display: flex; flex-direction: column; gap: 20px; min-width: 0; }

    /* ── PREVIEW PANEL ── */
    .preview-panel {
      position: sticky;
      top: 24px;
      display: flex;
      flex-direction: column;
      gap: 12px;
      max-height: calc(100vh - 48px);
      overflow-y: auto;
      scrollbar-width: none;
    }
    .preview-panel::-webkit-scrollbar { display: none; }

    /* ── DISCOUNT / RETENTION TOGGLES ── */
    .toggle-row { display: flex; align-items: center; gap: 10px; }
    .toggle-row label {
      font-family: var(--font-body);
      font-size: 14px; font-weight: 500;
      cursor: pointer; display: flex; align-items: center; gap: 8px;
      color: var(--text);
    }
    .sub-fields { display: none; margin-top: 14px; }
    .sub-fields.visible { display: grid; }

    /* ── RESPONSIVE ── */
    @media (max-width: 980px) {
      .editor-layout { grid-template-columns: 1fr; }
      .preview-panel {
        position: static;
        max-height: none;
        overflow-y: visible;
      }
    }

    @media (max-width: 640px) {
      body { padding: 20px 16px 60px; }
      .editor-actions > * {
        flex: 1 1 calc(50% - 8px);
        justify-content: center;
      }
    }
  </style>
</head>
<body>
  <div class="page">

    <AppNav current="editor" suffix="Editor" />

    <div class="editor-actions" aria-label="Acciones del editor">
        <label class="btn btn-ghost btn-sm" style="cursor:pointer;">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>
          </svg>
          Cargar JSON
          <input type="file" id="json-upload" accept=".json" style="display:none;" />
        </label>
        <button class="btn btn-ghost btn-sm" id="btn-reset">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <polyline points="1 4 1 10 7 10"/>
            <path d="M3.51 15a9 9 0 1 0 .49-4.7L1 10"/>
          </svg>
          Resetear
        </button>
        <button class="btn btn-dark btn-sm" id="btn-save">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
            <polyline points="17 21 17 13 7 13 7 21"/>
            <polyline points="7 3 7 8 15 8"/>
          </svg>
          Guardar
        </button>
        <button class="btn btn-ghost btn-sm" id="btn-download-json">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          Descargar JSON
        </button>
        <a href="/cuenta" class="btn btn-primary btn-sm" id="btn-view-current">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
            <circle cx="12" cy="12" r="3"/>
          </svg>
          Ver factura
        </a>
    </div>

    <div class="editor-layout">

      <!-- ── FORM PANEL ── -->
      <div class="form-panel">

        <!-- DOCUMENTO -->
        <SectionCard title="Documento" badge="var">
          <div class="field-grid col3">
            <div class="field">
              <label for="f-doc-number">N.° Documento</label>
              <input type="text" id="f-doc-number" class="mono" placeholder="CC-2026-001" />
            </div>
            <div class="field">
              <label for="f-status">Estado</label>
              <select id="f-status">
                <option value="pending">Pendiente de pago</option>
                <option value="paid">Pagado</option>
              </select>
            </div>
            <div class="field">
              <label for="f-issued">Fecha de emisión</label>
              <input type="date" id="f-issued" class="mono" />
              <span class="field-hint">Vacío = hoy automáticamente</span>
            </div>
          </div>
          <div class="field-grid">
            <div class="field">
              <label for="f-period">Período de servicio</label>
              <input type="text" id="f-period" class="mono" placeholder="Mayo 2026" />
            </div>
            <div class="field">
              <label for="f-due">Fecha límite de pago</label>
              <input type="date" id="f-due" class="mono" />
            </div>
          </div>
        </SectionCard>

        <!-- PRESTADOR (solo lectura) -->
        <SectionCard title="Prestador (tú)" badge="const">
          <p class="field-hint">
            Datos constantes guardados en este navegador.
            <a href="/configuracion" style="color:var(--emerald);font-weight:600;text-decoration:none;">Editar configuración</a>
          </p>
          <div class="field-grid">
            <div class="field">
              <label>Nombre</label>
              <input type="text" id="prov-name-disp" readonly />
            </div>
            <div class="field">
              <label>CC / NIT</label>
              <input type="text" id="prov-cc-disp" class="mono" readonly />
            </div>
            <div class="field">
              <label>Email</label>
              <input type="text" id="prov-email-disp" readonly />
            </div>
            <div class="field">
              <label>Teléfono</label>
              <input type="text" id="prov-phone-disp" class="mono" readonly />
            </div>
          </div>
        </SectionCard>

        <!-- CLIENTE -->
        <SectionCard title="Cliente" badge="var">
          <div class="field-grid">
            <div class="field">
              <label for="f-client-name">Nombre / Empresa</label>
              <input type="text" id="f-client-name" placeholder="Empresa Cliente S.A.S." />
            </div>
            <div class="field">
              <label for="f-client-nit">NIT</label>
              <input type="text" id="f-client-nit" class="mono" placeholder="900.123.456-7" />
            </div>
            <div class="field">
              <label for="f-client-contact">Contacto</label>
              <input type="text" id="f-client-contact" placeholder="Nombre del contacto" />
            </div>
            <div class="field">
              <label for="f-client-email">Email</label>
              <input type="email" id="f-client-email" placeholder="pagos@empresa.co" />
            </div>
            <div class="field field-full">
              <label for="f-client-address">Dirección</label>
              <input type="text" id="f-client-address" placeholder="Calle 72 #10-34, Of. 502" />
            </div>
            <div class="field field-full">
              <label for="f-client-city">Ciudad</label>
              <input type="text" id="f-client-city" placeholder="Medellín, Colombia" />
            </div>
          </div>
        </SectionCard>

        <!-- SERVICIOS / ÍTEMS -->
        <SectionCard title="Servicios / Ítems" badge="var">
          <div id="items-list" class="items-list"></div>
          <button class="add-item-btn" id="add-item-btn">+ Agregar ítem</button>
        </SectionCard>

        <!-- DESCUENTO -->
        <SectionCard title="Descuento" badge="var">
          <div class="toggle-row">
            <label>
              <input type="checkbox" id="f-disc-enabled" />
              Aplicar descuento
            </label>
          </div>
          <div class="sub-fields field-grid col3" id="disc-sub-fields">
            <div class="field">
              <label for="f-disc-type">Tipo</label>
              <select id="f-disc-type">
                <option value="percentage">Porcentaje (%)</option>
                <option value="fixed">Monto fijo ($)</option>
              </select>
            </div>
            <div class="field">
              <label for="f-disc-value">Valor</label>
              <input type="number" id="f-disc-value" class="mono" min="0" value="0" />
            </div>
            <div class="field">
              <label for="f-disc-desc">Descripción</label>
              <input type="text" id="f-disc-desc" placeholder="Ej: Pronto pago" />
            </div>
          </div>
        </SectionCard>

        <!-- RETENCIÓN -->
        <SectionCard title="Retención en la fuente" badge="var">
          <div class="toggle-row">
            <label>
              <input type="checkbox" id="f-ret-enabled" />
              Aplicar retención
            </label>
          </div>
          <div class="sub-fields field-grid" id="ret-sub-fields">
            <div class="field">
              <label for="f-ret-label">Etiqueta</label>
              <input type="text" id="f-ret-label" placeholder="Retención en la fuente" />
            </div>
            <div class="field">
              <label for="f-ret-rate">Porcentaje (%)</label>
              <input type="number" id="f-ret-rate" class="mono" min="0" max="100" value="10" />
            </div>
          </div>
        </SectionCard>

        <!-- NOTAS -->
        <SectionCard title="Notas" badge="var">
          <div class="field">
            <label for="f-notes">Texto de notas</label>
            <textarea id="f-notes" rows="4" placeholder="Instrucciones de pago, términos, etc."></textarea>
          </div>
        </SectionCard>

      </div>
      <!-- /form-panel -->

      <!-- ── PREVIEW PANEL ── -->
      <div class="preview-panel">
        <JsonPreview />
        <TotalsPreview />
      </div>

    </div>
    <!-- /editor-layout -->

  </div>

  <script type="application/json" id="default-data" set:html={defaultData}></script>

  <script>
    import {
      applySettingsToPage,
      getProviderFromSettings,
      getSettings,
    } from '../scripts/app-settings.js';
    import {
      getInvoiceRecord,
      getNextDocumentNumber,
      migrateLegacyInvoice,
      registerPwa,
      saveInvoice,
    } from '../scripts/invoice-store.js';

    const defaults = JSON.parse(document.getElementById('default-data').textContent);
    let inv = JSON.parse(JSON.stringify(defaults.invoice));
    let prov = getProviderFromSettings();
    let currentRecordId = null;

    // ── Helpers ──────────────────────────────────────────────────
    function fmt(n) {
      return '$ ' + Math.round(n).toLocaleString('es-CO');
    }

    function calcTotals(invoice) {
      const subtotal = invoice.items.reduce(
        (s, it) => s + (parseFloat(it.quantity) || 0) * (parseFloat(it.unitPrice) || 0), 0
      );
      const disc = invoice.discount || {};
      let discountAmt = 0;
      if (disc.enabled) {
        discountAmt = disc.type === 'percentage'
          ? subtotal * ((parseFloat(disc.value) || 0) / 100)
          : (parseFloat(disc.value) || 0);
      }
      const net = subtotal - discountAmt;
      const retentionAmt = invoice.retention?.enabled
        ? net * ((parseFloat(invoice.retention.rate) || 0) / 100)
        : 0;
      return { subtotal, discountAmt, net, retentionAmt, total: net - retentionAmt };
    }

    function escAttr(str) {
      return (str || '').replace(/&/g, '&amp;').replace(/"/g, '&quot;')
        .replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    // ── Read form → invoice object ────────────────────────────────
    function readForm() {
      return {
        documentNumber: document.getElementById('f-doc-number').value,
        status:         document.getElementById('f-status').value,
        issuedAt:       document.getElementById('f-issued').value,
        servicePeriod:  document.getElementById('f-period').value,
        dueDate:        document.getElementById('f-due').value,
        client: {
          name:    document.getElementById('f-client-name').value,
          nit:     document.getElementById('f-client-nit').value,
          contact: document.getElementById('f-client-contact').value,
          email:   document.getElementById('f-client-email').value,
          address: document.getElementById('f-client-address').value,
          city:    document.getElementById('f-client-city').value,
        },
        items: readItems(),
        discount: {
          enabled:     document.getElementById('f-disc-enabled').checked,
          type:        document.getElementById('f-disc-type').value,
          value:       parseFloat(document.getElementById('f-disc-value').value) || 0,
          description: document.getElementById('f-disc-desc').value,
        },
        retention: {
          enabled: document.getElementById('f-ret-enabled').checked,
          rate:    parseFloat(document.getElementById('f-ret-rate').value) || 0,
          label:   document.getElementById('f-ret-label').value,
        },
        notes: document.getElementById('f-notes').value,
      };
    }

    function readItems() {
      return Array.from(document.querySelectorAll('#items-list .item-card')).map(card => ({
        name:        card.querySelector('.it-name').value,
        description: card.querySelector('.it-desc').value,
        quantity:    parseFloat(card.querySelector('.it-qty').value) || 0,
        unit:        card.querySelector('.it-unit').value,
        unitPrice:   parseFloat(card.querySelector('.it-price').value) || 0,
      }));
    }

    // ── Update JSON preview + totals sidebar ──────────────────────
    function updatePreview() {
      inv = readForm();
      document.getElementById('json-preview').textContent = JSON.stringify(inv, null, 2);

      const { subtotal, discountAmt, retentionAmt, total } = calcTotals(inv);

      // Per-item totals
      document.querySelectorAll('#items-list .item-card').forEach(card => {
        const qty   = parseFloat(card.querySelector('.it-qty').value) || 0;
        const price = parseFloat(card.querySelector('.it-price').value) || 0;
        const disp  = card.querySelector('.item-total-disp');
        if (disp) disp.textContent = fmt(qty * price);
      });

      // Totals sidebar
      document.getElementById('tp-subtotal').textContent = fmt(subtotal);

      const discRow = document.getElementById('tp-disc-row');
      if (inv.discount.enabled && discountAmt > 0) {
        discRow.style.display = '';
        const lbl = inv.discount.type === 'percentage'
          ? inv.discount.value + '%' : 'fijo';
        document.getElementById('tp-disc-label').textContent =
          inv.discount.description
            ? `Descuento — ${inv.discount.description}`
            : `Descuento (${lbl})`;
        document.getElementById('tp-disc-value').textContent = '− ' + fmt(discountAmt);
      } else {
        discRow.style.display = 'none';
      }

      const retRow = document.getElementById('tp-ret-row');
      if (inv.retention.enabled) {
        retRow.style.display = '';
        document.getElementById('tp-ret-label').textContent =
          `${inv.retention.label} (${inv.retention.rate}%)`;
        document.getElementById('tp-ret-value').textContent = '− ' + fmt(retentionAmt);
      } else {
        retRow.style.display = 'none';
      }

      document.getElementById('tp-total').textContent = fmt(total);
    }

    // ── Add item card ─────────────────────────────────────────────
    function addItemCard(item) {
      item = item || { name: '', description: '', quantity: 1, unit: 'hrs', unitPrice: 0 };
      const card = document.createElement('div');
      card.className = 'item-card';
      card.innerHTML = `
        <div class="item-card-top">
          <div class="field" style="flex:1;min-width:0">
            <label>Nombre del servicio</label>
            <input type="text" class="it-name" value="${escAttr(item.name)}"
              placeholder="Desarrollo web, diseño, consultoría..." />
          </div>
          <button class="remove-btn" title="Eliminar ítem" type="button">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <polyline points="3 6 5 6 21 6"/>
              <path d="M19 6l-1 14H6L5 6"/>
              <path d="M10 11v6M14 11v6"/>
              <path d="M9 6V4h6v2"/>
            </svg>
          </button>
        </div>
        <div class="field" style="margin-bottom:10px">
          <label>Descripción (opcional)</label>
          <input type="text" class="it-desc" value="${escAttr(item.description)}"
            placeholder="Detalle del servicio prestado" />
        </div>
        <div class="item-values">
          <div class="field">
            <label>Cant.</label>
            <input type="number" class="it-qty mono" value="${item.quantity}" min="0" step="0.5" />
          </div>
          <div class="field">
            <label>Unidad</label>
            <input type="text" class="it-unit" value="${escAttr(item.unit)}" placeholder="hrs" />
          </div>
          <div class="field">
            <label>Valor unitario</label>
            <input type="number" class="it-price mono" value="${item.unitPrice}" min="0" step="1000" />
          </div>
          <div class="field">
            <label>Total</label>
            <div class="item-total-disp">${fmt((item.quantity || 0) * (item.unitPrice || 0))}</div>
          </div>
        </div>
      `;
      card.querySelectorAll('input').forEach(inp => inp.addEventListener('input', updatePreview));
      card.querySelector('.remove-btn').addEventListener('click', () => {
        card.remove(); updatePreview();
      });
      document.getElementById('items-list').appendChild(card);
    }

    // ── Populate form from invoice object ─────────────────────────
    function populateForm(invoice) {
      document.getElementById('f-doc-number').value = invoice.documentNumber || '';
      document.getElementById('f-status').value     = invoice.status || 'pending';
      document.getElementById('f-issued').value     = invoice.issuedAt || '';
      document.getElementById('f-period').value     = invoice.servicePeriod || '';
      document.getElementById('f-due').value        = invoice.dueDate || '';

      const c = invoice.client || {};
      document.getElementById('f-client-name').value    = c.name    || '';
      document.getElementById('f-client-nit').value     = c.nit     || '';
      document.getElementById('f-client-contact').value = c.contact || '';
      document.getElementById('f-client-email').value   = c.email   || '';
      document.getElementById('f-client-address').value = c.address || '';
      document.getElementById('f-client-city').value    = c.city    || '';

      const d = invoice.discount || {};
      document.getElementById('f-disc-enabled').checked = !!d.enabled;
      document.getElementById('disc-sub-fields').classList.toggle('visible', !!d.enabled);
      document.getElementById('f-disc-type').value  = d.type  || 'percentage';
      document.getElementById('f-disc-value').value = d.value || 0;
      document.getElementById('f-disc-desc').value  = d.description || '';

      const r = invoice.retention || {};
      document.getElementById('f-ret-enabled').checked = !!r.enabled;
      document.getElementById('ret-sub-fields').classList.toggle('visible', !!r.enabled);
      document.getElementById('f-ret-rate').value  = r.rate  || 10;
      document.getElementById('f-ret-label').value = r.label || 'Retención en la fuente';

      document.getElementById('f-notes').value = invoice.notes || '';

      document.getElementById('items-list').innerHTML = '';
      (invoice.items || []).forEach(item => addItemCard(item));

      updatePreview();
    }

    async function populateNewInvoice(baseInvoice = defaults.invoice) {
      currentRecordId = null;
      const invoice = JSON.parse(JSON.stringify(baseInvoice));
      invoice.documentNumber = await getNextDocumentNumber();
      populateForm(invoice);
      updateViewLink(null);
    }

    function updateViewLink(recordId) {
      const viewLink = document.getElementById('btn-view-current');
      if (!viewLink) return;
      viewLink.href = recordId ? `/cuenta?id=${encodeURIComponent(recordId)}` : '/cuenta';
    }

    function setSaveFeedback(text) {
      const btn = document.getElementById('btn-save');
      btn.textContent = text;
      setTimeout(() => {
        btn.innerHTML = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg> Guardar`;
      }, 1500);
    }

    async function saveCurrentInvoice() {
      try {
        const record = await saveInvoice(readForm(), { id: currentRecordId });
        currentRecordId = record.id;
        populateForm(record.invoice);
        updateViewLink(record.id);
        setSaveFeedback('Guardado');
        return record;
      } catch (error) {
        if (error?.code === 'DUPLICATE_DOCUMENT_NUMBER') {
          alert(error.message);
          return null;
        }
        alert('No se pudo guardar la cuenta de cobro.');
        return null;
      }
    }

    // ── Provider display (read-only) ──────────────────────────────
    function populateProviderDisplay() {
      prov = getProviderFromSettings();
      applySettingsToPage(getSettings());
      document.getElementById('prov-name-disp').value  = prov.name;
      document.getElementById('prov-cc-disp').value    = prov.cc;
      document.getElementById('prov-email-disp').value = prov.email;
      document.getElementById('prov-phone-disp').value = prov.phone;
    }

    // ── Wire static form listeners ────────────────────────────────
    function wireFormListeners() {
      [
        'f-doc-number', 'f-status', 'f-issued', 'f-period', 'f-due',
        'f-client-name', 'f-client-nit', 'f-client-contact',
        'f-client-email', 'f-client-address', 'f-client-city',
        'f-disc-type', 'f-disc-value', 'f-disc-desc',
        'f-ret-rate', 'f-ret-label',
        'f-notes',
      ].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.addEventListener('input', updatePreview);
      });

      ['f-status', 'f-disc-type'].forEach(id =>
        document.getElementById(id).addEventListener('change', updatePreview)
      );

      document.getElementById('f-disc-enabled').addEventListener('change', function() {
        document.getElementById('disc-sub-fields').classList.toggle('visible', this.checked);
        updatePreview();
      });
      document.getElementById('f-ret-enabled').addEventListener('change', function() {
        document.getElementById('ret-sub-fields').classList.toggle('visible', this.checked);
        updatePreview();
      });
    }

    // ── Buttons ───────────────────────────────────────────────────
    document.getElementById('add-item-btn').addEventListener('click', () => {
      addItemCard(null); updatePreview();
    });

    document.getElementById('btn-reset').addEventListener('click', () => {
      if (confirm('¿Resetear al ejemplo por defecto? Se perderán los cambios no guardados.')) {
        populateNewInvoice(defaults.invoice);
      }
    });

    document.getElementById('btn-save').addEventListener('click', saveCurrentInvoice);

    document.getElementById('btn-save-preview').addEventListener('click', async () => {
      const record = await saveCurrentInvoice();
      if (record) window.location.href = `/cuenta?id=${encodeURIComponent(record.id)}`;
    });

    document.getElementById('btn-download-json').addEventListener('click', () => {
      const data = readForm();
      const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `cuenta-cobro-${data.documentNumber || 'draft'}.json`;
      a.click();
      URL.revokeObjectURL(url);
    });

    document.getElementById('btn-copy').addEventListener('click', function() {
      navigator.clipboard.writeText(document.getElementById('json-preview').textContent)
        .then(() => {
          this.textContent = '✓ Copiado';
          setTimeout(() => this.textContent = 'Copiar', 1500);
        });
    });

    document.getElementById('json-upload').addEventListener('change', function(e) {
      const file = e.target.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = async ev => {
        try {
          const parsed = JSON.parse(ev.target.result);
          parsed.documentNumber = parsed.documentNumber || await getNextDocumentNumber();
          currentRecordId = null;
          populateForm(parsed);
          updateViewLink(null);
        } catch {
          alert('El archivo JSON no es válido.');
        }
      };
      reader.readAsText(file);
      e.target.value = '';
    });

    // ── Init ──────────────────────────────────────────────────────
    async function init() {
      registerPwa();
      populateProviderDisplay();
      wireFormListeners();
      await migrateLegacyInvoice(inv);

      const params = new URLSearchParams(window.location.search);
      const id = params.get('id');
      const duplicateId = params.get('duplicate');

      if (duplicateId) {
        const source = await getInvoiceRecord(duplicateId);
        if (source) {
          const copy = JSON.parse(JSON.stringify(source.invoice));
          copy.documentNumber = await getNextDocumentNumber();
          currentRecordId = null;
          populateForm(copy);
          updateViewLink(null);
          return;
        }
      }

      if (id) {
        const record = await getInvoiceRecord(id);
        if (record) {
          currentRecordId = record.id;
          populateForm(record.invoice);
          updateViewLink(record.id);
          return;
        }
      }

      await populateNewInvoice(inv);
    }

    init();
  </script>
</body>
</html>
