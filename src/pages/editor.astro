---
import { PROVIDER } from "../config/provider";
import defaultInvoice from "../data/invoice.default.json";
import AppLayout from "../layouts/AppLayout.astro";
import EditorActions from "../components/editor/EditorActions.astro";
import EditorWorkspace from "../components/editor/EditorWorkspace.astro";

const defaultData = JSON.stringify({
  invoice: defaultInvoice,
  provider: PROVIDER,
});
---

<AppLayout title="Editor — Cuenta de Cobro" current="editor" suffix="Editor">
  <style slot="head">
    body {
      padding: var(--page-pad) var(--page-pad) clamp(56px, 8vw, 80px);
    }
    .page {
      max-width: 1160px;
      margin: 0 auto;
      width: 100%;
    }

    .editor-actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      align-items: center;
      justify-content: flex-end;
      margin-bottom: var(--content-gap);
    }

    /* ── TWO-COLUMN LAYOUT ── */
    .editor-layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(300px, 340px);
      gap: var(--section-gap);
      align-items: start;
    }

    /* ── FORM PANEL ── */
    .form-panel {
      display: flex;
      flex-direction: column;
      gap: var(--content-gap);
      min-width: 0;
    }

    /* ── PREVIEW PANEL ── */
    .preview-panel {
      position: sticky;
      top: 24px;
      display: flex;
      flex-direction: column;
      gap: 12px;
      max-height: calc(100vh - 48px);
      overflow-y: auto;
      scrollbar-width: none;
    }
    .preview-panel::-webkit-scrollbar {
      display: none;
    }

    /* ── DISCOUNT / RETENTION TOGGLES ── */
    .toggle-row {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .toggle-row label {
      font-family: var(--font-body);
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 8px;
      color: var(--text);
    }
    .sub-fields {
      display: none;
      margin-top: 14px;
    }
    .sub-fields.visible {
      display: grid;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 980px) {
      .editor-layout {
        grid-template-columns: 1fr;
      }
      .preview-panel {
        position: static;
        max-height: none;
        overflow-y: visible;
      }
    }

    @media (max-width: 640px) {
      .editor-actions {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .editor-actions > * {
        justify-content: center;
        min-width: 0;
      }
    }

    @media (max-width: 420px) {
      .editor-actions {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <EditorActions />
  <EditorWorkspace />

  <script
    slot="scripts"
    type="application/json"
    id="default-data"
    set:html={defaultData}
  />

  <script slot="scripts">
    import { initEditorPage } from "../scripts/pages/editor-page.js";

    initEditorPage();
  </script>
</AppLayout>
