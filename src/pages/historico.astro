---
import '../styles/design-system.css';
import AppNav from '../components/AppNav.astro';
import defaultInvoice from '../data/invoice.default.json';

const defaultData = JSON.stringify(defaultInvoice);
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Histórico — Cuenta de Cobro</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="manifest" href="/manifest.webmanifest" />

  <style is:global>
    body { padding: var(--page-pad) var(--page-pad) clamp(56px, 8vw, 80px); }
    .page { max-width: 1080px; margin: 0 auto; width: 100%; }

    .history-hero {
      background: var(--black);
      border-radius: var(--r-xl);
      box-shadow: var(--shadow-lg);
      padding: clamp(24px, 4vw, 34px) clamp(20px, 5vw, 38px);
      margin-bottom: var(--content-gap);
      color: #fff;
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(260px, 360px);
      gap: var(--content-gap);
      align-items: end;
    }
    .eyebrow {
      font-family: var(--font-mono);
      font-size: 10px; letter-spacing: 2px;
      text-transform: uppercase; color: var(--emerald);
      margin-bottom: 8px;
    }
    .history-title {
      font-family: var(--font-heading);
      font-size: clamp(2rem, 5vw, 4rem);
      line-height: .95;
      color: var(--gold);
      letter-spacing: -2px;
      margin-bottom: 12px;
    }
    .history-copy {
      max-width: 56ch;
      color: rgba(255,255,255,.58);
      font-size: 14px;
    }
    .search-box {
      width: 100%;
      border: 1.5px solid rgba(255,255,255,.18);
      background: rgba(255,255,255,.08);
      color: #fff;
      border-radius: var(--r-full);
      padding: 13px 18px;
      font-family: var(--font-body);
      outline: none;
    }
    .search-box::placeholder { color: rgba(255,255,255,.38); }
    .search-box:focus {
      border-color: var(--gold);
      box-shadow: 0 0 0 4px rgba(242,183,5,.12);
    }

    .empty-state {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--r-xl);
      box-shadow: var(--shadow-md);
      padding: 34px;
      text-align: center;
      color: var(--text-secondary);
    }
    .empty-state strong {
      display: block;
      font-family: var(--font-heading);
      font-size: 1.3rem;
      color: var(--text);
      margin-bottom: 8px;
    }

    .client-group {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--r-xl);
      box-shadow: var(--shadow-sm);
      overflow: hidden;
      margin-bottom: 18px;
    }
    .client-heading {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding: 18px 22px;
      background: var(--gray-100);
      border-bottom: 1px solid var(--warm-border);
    }
    .client-name {
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: 1.05rem;
    }
    .client-count {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--gray-600);
    }
    .invoice-row {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 18px;
      padding: 18px 22px;
      border-bottom: 1px solid var(--gray-100);
    }
    .invoice-row:last-child { border-bottom: none; }
    .invoice-title {
      font-family: var(--font-body);
      font-weight: 700;
      color: var(--text);
      margin-bottom: 4px;
    }
    .invoice-meta {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--gray-600);
    }
    .invoice-actions {
      display: flex;
      gap: 7px;
      align-items: center;
      flex-wrap: wrap;
      justify-content: flex-end;
    }
    .danger-btn {
      color: #a13030;
      border-color: #efc7c7;
    }
    .danger-btn:hover {
      color: #7f1d1d;
      border-color: #d97979;
      background: #fff2f2;
    }

    @media (max-width: 760px) {
      .history-hero { grid-template-columns: 1fr; }
      .invoice-row { grid-template-columns: 1fr; }
      .invoice-actions {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        justify-content: stretch;
      }
      .invoice-actions > * { justify-content: center; }
    }

    @media (max-width: 440px) {
      .client-heading {
        align-items: flex-start;
        flex-direction: column;
      }

      .invoice-actions {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <div class="page">
    <AppNav current="historico" suffix="Histórico" />

    <section class="history-hero">
      <div>
        <p class="eyebrow">Base local del navegador</p>
        <h1 class="history-title">Histórico de cuentas</h1>
        <p class="history-copy">
          Las cuentas se guardan por cliente en IndexedDB. Puedes abrir, editar,
          duplicar o eliminar cada registro sin depender de un backend.
        </p>
      </div>
      <input
        type="search"
        id="history-search"
        class="search-box"
        placeholder="Buscar por cliente, NIT, número o título"
      />
    </section>

    <div id="history-root"></div>
  </div>

  <script type="application/json" id="default-invoice" set:html={defaultData}></script>

  <script>
    import {
      applySettingsToPage,
      getSettings,
    } from '../scripts/app-settings.js';
    import {
      deleteInvoiceRecord,
      listInvoices,
      migrateLegacyInvoice,
      registerPwa,
    } from '../scripts/invoice-store.js';

    let invoices = [];
    const defaultInvoice = JSON.parse(document.getElementById('default-invoice').textContent);
    const root = document.getElementById('history-root');
    const search = document.getElementById('history-search');

    function fmtDate(iso) {
      if (!iso) return 'Sin fecha';
      return new Date(iso).toLocaleDateString('es-CO', {
        day: 'numeric',
        month: 'short',
        year: 'numeric',
      });
    }

    function normalize(value) {
      return String(value || '')
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .toLowerCase();
    }

    function escapeHtml(value) {
      return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    function getSearchHaystack(record) {
      const client = record.invoice?.client || {};
      return normalize([
        record.title,
        record.documentNumber,
        client.name,
        client.nit,
        client.contact,
        client.email,
      ].join(' '));
    }

    function groupByClient(records) {
      const groups = new Map();
      records.forEach(record => {
        const name = record.invoice?.client?.name?.trim() || 'Cliente sin nombre';
        if (!groups.has(record.clientKey)) groups.set(record.clientKey, { name, records: [] });
        groups.get(record.clientKey).records.push(record);
      });
      return Array.from(groups.values());
    }

    function render() {
      const query = normalize(search.value);
      const filtered = query
        ? invoices.filter(record => getSearchHaystack(record).includes(query))
        : invoices;

      if (!filtered.length) {
        root.innerHTML = `
          <div class="empty-state">
            <strong>No hay cuentas para mostrar</strong>
            <p>${query ? 'Prueba con otra búsqueda.' : 'Crea tu primera cuenta de cobro desde el editor.'}</p>
          </div>
        `;
        return;
      }

      root.innerHTML = groupByClient(filtered).map(group => `
        <section class="client-group">
          <div class="client-heading">
            <div class="client-name">${escapeHtml(group.name)}</div>
            <div class="client-count">${group.records.length} cuenta${group.records.length === 1 ? '' : 's'}</div>
          </div>
          ${group.records.map(record => {
            const client = record.invoice?.client || {};
            return `
              <article class="invoice-row">
                <div>
                  <p class="invoice-title">${escapeHtml(record.title)}</p>
                  <div class="invoice-meta">
                    <span>${escapeHtml(record.documentNumber)}</span>
                    <span>${escapeHtml(client.nit || 'Sin NIT')}</span>
                    <span>Actualizada ${fmtDate(record.updatedAt)}</span>
                  </div>
                </div>
                <div class="invoice-actions">
                  <a class="btn btn-primary btn-sm" href="/cuenta?id=${encodeURIComponent(record.id)}">Ver</a>
                  <a class="btn btn-ghost btn-sm" href="/editor?id=${encodeURIComponent(record.id)}">Editar</a>
                  <a class="btn btn-ghost btn-sm" href="/editor?duplicate=${encodeURIComponent(record.id)}">Duplicar</a>
                  <button class="btn btn-ghost btn-sm danger-btn" data-delete-id="${escapeHtml(record.id)}">Eliminar</button>
                </div>
              </article>
            `;
          }).join('')}
        </section>
      `).join('');
    }

    async function refresh() {
      invoices = await listInvoices();
      render();
    }

    root.addEventListener('click', async event => {
      const button = event.target.closest('[data-delete-id]');
      if (!button) return;

      const id = button.getAttribute('data-delete-id');
      const record = invoices.find(item => item.id === id);
      if (!confirm(`¿Eliminar ${record?.documentNumber || 'esta cuenta'}? Esta acción no se puede deshacer.`)) {
        return;
      }

      await deleteInvoiceRecord(id);
      await refresh();
    });

    search.addEventListener('input', render);

    async function init() {
      registerPwa();
      applySettingsToPage(getSettings());
      await migrateLegacyInvoice(defaultInvoice);
      await refresh();
    }

    init();
  </script>
</body>
</html>
