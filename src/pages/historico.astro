---
import AppLayout from '../layouts/AppLayout.astro';
import HistoryHero from '../components/history/HistoryHero.astro';
import defaultInvoice from '../data/invoice.default.json';

const defaultData = JSON.stringify(defaultInvoice);
---

<AppLayout title="Histórico — Cuenta de Cobro" current="historico" suffix="Histórico">
  <style is:global slot="head">
    body { padding: var(--page-pad) var(--page-pad) clamp(56px, 8vw, 80px); }
    .page { max-width: 1080px; margin: 0 auto; width: 100%; }

    .history-hero {
      background: var(--black);
      border-radius: var(--r-xl);
      box-shadow: var(--shadow-lg);
      padding: clamp(24px, 4vw, 34px) clamp(20px, 5vw, 38px);
      margin-bottom: var(--content-gap);
      color: #fff;
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(260px, 360px);
      gap: var(--content-gap);
      align-items: end;
    }
    .eyebrow {
      font-family: var(--font-mono);
      font-size: 10px; letter-spacing: 2px;
      text-transform: uppercase; color: var(--emerald);
      margin-bottom: 8px;
    }
    .history-title {
      font-family: var(--font-heading);
      font-size: clamp(2rem, 5vw, 4rem);
      line-height: .95;
      color: var(--gold);
      letter-spacing: -2px;
      margin-bottom: 12px;
    }
    .history-copy {
      max-width: 56ch;
      color: rgba(255,255,255,.58);
      font-size: 14px;
    }
    .search-box {
      width: 100%;
      border: 1.5px solid rgba(255,255,255,.18);
      background: rgba(255,255,255,.08);
      color: #fff;
      border-radius: var(--r-full);
      padding: 13px 18px;
      font-family: var(--font-body);
      outline: none;
    }
    .search-box::placeholder { color: rgba(255,255,255,.38); }
    .search-box:focus {
      border-color: var(--gold);
      box-shadow: 0 0 0 4px rgba(242,183,5,.12);
    }

    .empty-state {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--r-xl);
      box-shadow: var(--shadow-md);
      padding: 34px;
      text-align: center;
      color: var(--text-secondary);
    }
    .empty-state strong {
      display: block;
      font-family: var(--font-heading);
      font-size: 1.3rem;
      color: var(--text);
      margin-bottom: 8px;
    }

    .client-group {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--r-xl);
      box-shadow: var(--shadow-sm);
      overflow: hidden;
      margin-bottom: 18px;
    }
    .client-heading {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding: 18px 22px;
      background: var(--gray-100);
      border-bottom: 1px solid var(--warm-border);
    }
    .client-name {
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: 1.05rem;
    }
    .client-count {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--gray-600);
    }
    .invoice-row {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 18px;
      padding: 18px 22px;
      border-bottom: 1px solid var(--gray-100);
    }
    .invoice-row:last-child { border-bottom: none; }
    .invoice-title {
      font-family: var(--font-body);
      font-weight: 700;
      color: var(--text);
      margin-bottom: 4px;
    }
    .invoice-meta {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--gray-600);
    }
    .invoice-actions {
      display: flex;
      gap: 7px;
      align-items: center;
      flex-wrap: wrap;
      justify-content: flex-end;
    }
    .danger-btn {
      color: #a13030;
      border-color: #efc7c7;
    }
    .danger-btn:hover {
      color: #7f1d1d;
      border-color: #d97979;
      background: #fff2f2;
    }

    @media (max-width: 760px) {
      .history-hero { grid-template-columns: 1fr; }
      .invoice-row { grid-template-columns: 1fr; }
      .invoice-actions {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        justify-content: stretch;
      }
      .invoice-actions > * { justify-content: center; }
    }

    @media (max-width: 440px) {
      .client-heading {
        align-items: flex-start;
        flex-direction: column;
      }

      .invoice-actions {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <HistoryHero />
  <div id="history-root"></div>

  <script slot="scripts" type="application/json" id="default-invoice" set:html={defaultData}></script>

  <script slot="scripts">
    import { initHistoryPage } from '../scripts/pages/history-page.js';

    const defaultInvoice = JSON.parse(document.getElementById('default-invoice').textContent);
    initHistoryPage(defaultInvoice);
  </script>
</AppLayout>
