---
import AppLayout from '../layouts/AppLayout.astro';
import HomeHero from '../components/home/HomeHero.astro';
import QuickLinks from '../components/home/QuickLinks.astro';
---

<AppLayout title="Inicio — Cuenta de Cobro" current="inicio">
  <style slot="head">
    body { padding: var(--page-pad) var(--page-pad) clamp(48px, 8vw, 72px); }
    .page { max-width: 1120px; margin: 0 auto; width: 100%; }

    .home-hero {
      display: grid;
      grid-template-columns: minmax(0, 1.08fr) minmax(300px, .92fr);
      gap: var(--section-gap);
      align-items: center;
      min-height: min(680px, calc(100vh - 170px));
      padding-bottom: var(--section-gap);
    }

    .eyebrow {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 1.8px;
      text-transform: uppercase;
      color: var(--emerald);
      margin-bottom: 14px;
      font-weight: 700;
    }

    .home-title {
      font-family: var(--font-heading);
      font-size: clamp(2.8rem, 8vw, 6.4rem);
      line-height: .92;
      color: var(--black);
      max-width: 8.5ch;
    }

    .home-copy {
      margin-top: 22px;
      max-width: 58ch;
      color: var(--text-secondary);
      font-size: clamp(15px, 2vw, 17px);
      line-height: 1.75;
    }

    .hero-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      align-items: center;
      margin-top: 30px;
    }

    .home-panel {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--r-lg);
      box-shadow: var(--shadow-lg);
      overflow: hidden;
    }

    .panel-head {
      background: var(--black);
      color: #fff;
      padding: 26px;
    }

    .panel-title {
      font-family: var(--font-heading);
      color: var(--gold);
      font-size: 1.5rem;
      line-height: 1.1;
      margin-bottom: 8px;
    }

    .panel-copy {
      color: rgba(255,255,255,.62);
      font-size: 14px;
    }

    .flow-list {
      display: grid;
      gap: 0;
    }

    .flow-step {
      display: grid;
      grid-template-columns: 42px minmax(0, 1fr);
      gap: 14px;
      padding: 20px 24px;
      border-bottom: 1px solid var(--gray-200);
    }

    .flow-step:last-child { border-bottom: none; }

    .step-number {
      width: 34px;
      height: 34px;
      border-radius: var(--r-full);
      display: grid;
      place-items: center;
      background: var(--gold-subtle);
      color: var(--gold-dark);
      font-family: var(--font-mono);
      font-size: 12px;
      font-weight: 800;
    }

    .step-title {
      font-weight: 800;
      color: var(--text);
      margin-bottom: 3px;
    }

    .step-copy {
      color: var(--text-secondary);
      font-size: 14px;
      line-height: 1.55;
    }

    .quick-links {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 14px;
      margin-top: 4px;
    }

    .quick-link {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--r-md);
      padding: 18px;
      text-decoration: none;
      color: inherit;
      box-shadow: var(--shadow-sm);
      transition: transform .18s ease, border-color .18s ease, box-shadow .18s ease;
    }

    .quick-link:hover {
      transform: translateY(-2px);
      border-color: var(--gold);
      box-shadow: var(--shadow-md);
    }

    .quick-link strong {
      display: block;
      font-family: var(--font-heading);
      font-size: 1.1rem;
      margin-bottom: 6px;
    }

    .quick-link span {
      color: var(--text-secondary);
      font-size: 13px;
      line-height: 1.5;
    }

    @media (max-width: 880px) {
      .home-hero {
        grid-template-columns: 1fr;
        min-height: 0;
        padding-bottom: 24px;
      }
      .home-title { max-width: 10ch; }
      .quick-links { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }

    @media (max-width: 520px) {
      .quick-links { grid-template-columns: 1fr; }
      .panel-head { padding: 22px; }
      .hero-actions > * {
        width: 100%;
        justify-content: center;
      }
      .flow-step {
        grid-template-columns: 1fr;
        gap: 10px;
      }
    }
  </style>

  <main>
    <HomeHero />
    <QuickLinks />
  </main>

  <script slot="scripts">
    import { initStaticPage } from '../scripts/page-lifecycle.js';

    initStaticPage();
  </script>
</AppLayout>
